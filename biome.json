{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
    	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
    	"files": {
		"includes": ["**"]
	},	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"useImportType": "on"
			}
		}
	},
    	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	}
}